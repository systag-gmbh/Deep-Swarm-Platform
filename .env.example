# ===================
# Postgres
# ===================
POSTGRES_PASSWORD=changeme
POSTGRES_USER=postgres

# ===================
# n8n
# ===================
N8N_DB=n8n
# Full external URL for n8n webhooks (protocol + host + port)
N8N_WEBHOOK_URL=https://localhost:8080/

# ===================
# LiteLLM
# ===================
LITELLM_DB=litellm
LITELLM_MASTER_KEY=sk-litellm-master-key
# LITELLM_PROXY_BASE_URL=https://localhost:8083
# Add API keys for providers you want to use:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ===================
# pgAdmin
# ===================
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# ===================
# Nextcloud
# ===================
NEXTCLOUD_DB=nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme
NEXTCLOUD_TRUSTED_DOMAINS=localhost

# ===================
# Restic Backup
# ===================
RESTIC_PASSWORD=backup-encryption-key

# ===================
# Garage (Object Storage)
# ===================
# Generate secrets with: openssl rand -hex 32
GARAGE_RPC_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
GARAGE_ADMIN_TOKEN=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# WebUI auth - generate with: htpasswd -nbBC 10 "username" "password"
# requires apache2-utils on Ubuntu
GARAGE_WEBUI_AUTH=admin:$2y$10$EXAMPLE_HASH_REPLACE_ME

# ===================
# RAGflow
# ===================
# Internal service passwords (change for production)
RAGFLOW_MYSQL_PASSWORD=infini_rag_flow
RAGFLOW_ES_PASSWORD=infini_rag_flow
RAGFLOW_MINIO_PASSWORD=infini_rag_flow
RAGFLOW_REDIS_PASSWORD=infini_rag_flow

# ===================
# Caddy Security
# ===================
# JWT signing key for authentication tokens
# Generate with: openssl rand -hex 32
CADDY_JWT_SHARED_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ===================
# Presidio PII Analyzer
# ===================
PRESIDIO_SCORE_THRESHOLD=0.5
PRESIDIO_EXCLUDED_ENTITIES=DATE_TIME,AGE,GENDER
PRESIDIO_AUDIT_LOGGING=false
# DANGER: logs actual PII values (testing only!)
# PRESIDIO_DANGER_AUDIT_LOG_PII=false

# ===================
# Skyvern
# ===================
# Host for Skyvern UI (used for WebSocket and API URLs)
SKYVERN_HOST=localhost
# LLM model to use (must be configured in LiteLLM)
SKYVERN_LLM_MODEL=openai/gpt-5.2
# LiteLLM API key (your LiteLLM master key)
SKYVERN_LLM_API_KEY=
# API key for Skyvern (generated on first run, or set manually)
SKYVERN_API_KEY=
# Enable saving logs as artifacts (useful for debugging)
SKYVERN_ENABLE_LOG_ARTIFACTS=false

# ===================
# Optional
# ===================
TZ=Europe/Berlin
